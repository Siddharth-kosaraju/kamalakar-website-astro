---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer.astro';
import { getSiteContent } from '../../utils/content';

const content = await getSiteContent('te');
---

<BaseLayout lang="te" class="min-h-screen bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300">
  <SEO
    slot="head"
    title="గోప్యతా విధానం | Kamalakar Heart Centre"
    description="Kamalakar Heart Centre గోప్యతా విధానం. మీ డేటా ఎలా సంరక్షించబడుతుంది."
    canonicalUrl="https://kamalakarheartcentre.com/te/privacy-policy/"
    lang="te"
    alternateLangUrl="https://kamalakarheartcentre.com/privacy-policy/"
    page="privacy"
  />

  <Header
    client:load
    lang="te"
    content={content.nav}
    appointmentPhone={content.contact.appointmentPhone}
    currentPage="home"
    currentPath={Astro.url.pathname}
  />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 pt-28">
    <h1 class="text-4xl font-bold mb-4 border-b-2 border-gray-300 dark:border-gray-700 pb-2">గోప్యతా విధానం</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-8"><strong>ప్రభావవంతమైన తేదీ:</strong> 25 జనవరి 2026</p>

    <div class="prose prose-lg dark:prose-invert max-w-none space-y-8">
      <section>
        <h2 class="text-2xl font-bold mt-8 mb-4">1. గోప్యతా విధానం పరిచయం</h2>
        <p>
          కమలాకర్ హార్ట్ సెంటర్ ("మేము", "మా", "మా") మీ గోప్యతను రక్షించడానికి నిబద్ధం.
          ఈ గోప్యతా విధానం మీరు <strong>kamalakarheartcentre.com</strong> ("వెబ్‌సైట్") సందర్శించినప్పుడు
          మేము మీ వ్యక్తిగత డేటాను ఎలా సేకరిస్తాము, ఉపయోగిస్తాము, నిల్వ చేస్తాము మరియు రక్షిస్తాము అని వివరిస్తుంది.
        </p>
        <p>
          ఈ విధానం సమాచార సాంకేతిక చట్టం, 2000,
          సమాచార సాంకేతిక (సహేతుకమైన భద్రతా పద్ధతులు మరియు విధానాలు మరియు సున్నితమైన వ్యక్తిగత డేటా లేదా సమాచారం) నియమాలు, 2011,
          మరియు డిజిటల్ వ్యక్తిగత డేటా రక్షణ చట్టం, 2023 ప్రకారం తయారు చేయబడింది.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold mt-8 mb-4">2. మేము సేకరించే సమాచారం</h2>
        <p>మేము ఈ క్రింది వర్గాల సమాచారాన్ని సేకరించవచ్చు:</p>
        <ul class="list-disc pl-6 space-y-2 mt-4">
          <li><strong>వ్యక్తిగత సమాచారం:</strong> పేరు, ఈమెయిల్ చిరునామా, ఫోన్ నంబర్ మరియు ఫారమ్‌ల ద్వారా స్వచ్ఛందంగా సమర్పించిన ఇతర వివరాలు.</li>
          <li><strong>ఆరోగ్య సంబంధిత సమాచారం:</strong> మీరు ప్రశ్నలు లేదా అపాయింట్‌మెంట్ అభ్యర్థనలలో స్వచ్ఛందంగా పంచుకున్న సమాచారం.</li>
          <li><strong>సాంకేతిక సమాచారం:</strong> IP చిరునామా, బ్రౌజర్ రకం, పరికర సమాచారం మరియు కుకీలు లేదా విశ్లేషణ సాధనాల ద్వారా సేకరించిన ఉపయోగ డేటా.</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold mt-8 mb-4">3. సేకరణ యొక్క ఉద్దేశ్యం</h2>
        <p>మీ సమాచారం ఈ క్రింది ఉద్దేశ్యాల కోసం ఉపయోగించబడవచ్చు:</p>
        <ul class="list-disc pl-6 space-y-2 mt-4">
          <li>ప్రశ్నలకు మరియు అపాయింట్‌మెంట్ అభ్యర్థనలకు ప్రతిస్పందించడం</li>
          <li>ఆరోగ్య సంరక్షణ సంబంధిత సమాచారం మరియు సేవలను అందించడం</li>
          <li>వెబ్‌సైట్ పనితీరు మరియు వినియోగదారు అనుభవాన్ని మెరుగుపరచడం</li>
          <li>చట్టపరమైన మరియు నియంత్రణ సమ్మతి</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold mt-8 mb-4">4. ప్రాసెసింగ్ కోసం చట్టపరమైన ఆధారం</h2>
        <p>
          మేము అననుమతిసమ ప్రాప్తి, మార్పు, ఆవిష్కరణ లేదా నాశనం నుండి రక్షించడానికి తగిన సాంకేతిక, ఆర్థిక మరియు భౌతిక సంరక్షణ చర్యలను అమలు చేస్తాము.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold mt-8 mb-4">5. కుకీలు మరియు ట్రాకింగ్</h2>
        <p>
          వెబ్‌సైట్ కార్యాచరణను మెరుగుపరచడానికి మరియు ఉపయోగ నమూనాలను విశ్లేషించడానికి
          కుకీలు మరియు సారూప్య సాంకేతికతలను ఉపయోగించవచ్చు. మీరు మీ బ్రౌజర్ సెట్టింగ్‌ల ద్వారా కుకీలను నియంత్రించవచ్చు.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold mt-8 mb-4">6. డేటా షేరింగ్ మరియు బహిర్గతం</h2>
        <p>మేము మీ వ్యక్తిగత డేటాను విక్రయించము లేదా అద్దెకు ఇవ్వము. మేము సమాచారాన్ని మాత్రమే షేర్ చేయవచ్చు:</p>
        <ul class="list-disc pl-6 space-y-2 mt-4">
          <li>వెబ్‌సైట్ కార్యాచరణలలో సహాయపడే అధికారం ఇవ్వబడిన సేవా ప్రదాతలతో</li>
          <li>చట్టం ద్వారా అవసరమైనప్పుడు నియంత్రణ లేదా చట్టపరమైన అధికారులతో</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold mt-8 mb-4">7. డేటా భద్రత</h2>
        <p>
          మేము అనధికార ప్రాప్తి, బహిర్గతం, మార్పు లేదా నాశనం నుండి వ్యక్తిగత డేటాను రక్షించడానికి
          సహేతుకమైన సాంకేతిక మరియు సంస్థాగత రక్షణలను అమలు చేస్తాము.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold mt-8 mb-4">8. డేటా నిలుపుదల</h2>
        <p>
          వ్యక్తిగత డేటా ఈ విధానంలో పేర్కొన్న ఉద్దేశ్యాలను నెరవేర్చడానికి అవసరమైనంత కాలం
          లేదా వర్తించే చట్టం ప్రకారం అవసరమైనంత కాలం మాత్రమే నిల్వ చేయబడుతుంది.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold mt-8 mb-4">9. మీ హక్కులు</h2>
        <p>మీకు హక్కు ఉంది:</p>
        <ul class="list-disc pl-6 space-y-2 mt-4">
          <li>మీ వ్యక్తిగత డేటాను యాక్సెస్ చేయడం</li>
          <li>తప్పు డేటాను సరిదిద్దడానికి అభ్యర్థన చేయడం</li>
          <li>వర్తించే చోట సమ్మతిని వెనక్కి తీసుకోవడం</li>
          <li>చట్టపరమైన బాధ్యతలకు లోబడి వ్యక్తిగత డేటాను తొలగించడానికి అభ్యర్థన చేయడం</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold mt-8 mb-4">10. పిల్లల గోప్యత</h2>
        <p>
          ఈ వెబ్‌సైట్ 18 సంవత్సరాల కంటే తక్కువ వయస్సు గల పిల్లల కోసం ఉద్దేశించబడలేదు.
          మేము తల్లిదండ్రుల సమ్మతి లేకుండా అల్పవయస్కుల నుండి వ్యక్తిగత డేటాను తెలిసి సేకరించము.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold mt-8 mb-4">11. ఈ విధానంలో నవీకరణలు</h2>
        <p>
          మేము చట్టం లేదా పద్ధతులలో మార్పులను ప్రతిబింబించడానికి ఈ గోప్యతా విధానాన్ని
          కాలక్రమేణా నవీకరించవచ్చు. నవీకరణలు సవరించిన ప్రభావవంతమైన తేదీతో ఈ పేజీలో పోస్ట్ చేయబడతాయి.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold mt-8 mb-4">12. సంపర్క సమాచారం</h2>
        <p>గోప్యత సంబంధిత ప్రశ్నలు లేదా అభ్యర్థనల కోసం, దయచేసి సంప్రదించండి:</p>
        <p class="mt-4">
          <strong>కమలాకర్ హార్ట్ సెంటర్</strong><br />
          ఈమెయిల్: <a href="mailto:info@kamalakarheartcentre.com" class="text-primary dark:text-accent-light hover:underline">info@kamalakarheartcentre.com</a><br />
          ఫోన్: <a href="tel:+919959423566" class="text-primary dark:text-accent-light hover:underline">+91 99594 23566</a><br />
          స్థానం: భారతదేశం
        </p>
      </section>

      <footer class="mt-12 pt-6 border-t border-gray-300 dark:border-gray-700 text-sm text-gray-600 dark:text-gray-400">
        &copy; 2026 కమలాకర్ హార్ట్ సెంటర్. అన్ని హక్కులు ప్రత్యేకించబడ్డాయి.
      </footer>
    </div>
  </main>

  <Footer content={content.footer} navContent={content.nav} lang="te" currentPage="home" />
</BaseLayout>
