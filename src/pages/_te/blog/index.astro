---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import Header from '../../../components/Header';
import Footer from '../../../components/Footer.astro';
import { getSiteContent } from '../../../utils/content';
import { getCollection } from 'astro:content';

const content = await getSiteContent('te');

// Get all published blog posts — TE version takes priority over EN for same slug
const tePosts = (await getCollection('blog-te')).filter(p => p.data.published);
const enPosts = (await getCollection('blog')).filter(p => p.data.published);
const teIds = new Set(tePosts.map(p => p.id));
const mergedPosts = [...tePosts, ...enPosts.filter(p => !teIds.has(p.id))];
const posts = mergedPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    url: 'https://kamalakarheartcentre.com/te/blog/',
    name: 'గుండె ఆరోగ్య బ్లాగ్ - కమలాకర్ హార్ట్ సెంటర్',
    description: 'గుంటూరులో ఇంటర్వెన్షనల్ కార్డియాలజిస్ట్ డాక్టర్ కమలాకర్ కోసరాజు నుండి నిపుణ కార్డియాక్ ఆరోగ్య వ్యాసాలు.',
    inLanguage: 'te',
    publisher: {
      '@type': 'Organization',
      name: 'Kamalakar Heart Centre',
      url: 'https://kamalakarheartcentre.com',
    },
  },
];
---

<BaseLayout lang="te" class="min-h-screen bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300">
  <SEO
    slot="head"
    title="గుండె ఆరోగ్య బ్లాగ్ | కమలాకర్ హార్ట్ సెంటర్ గుంటూరు"
    description="డాక్టర్ కమలాకర్ కోసరాజు నుండి నిపుణ కార్డియాక్ ఆరోగ్య వ్యాసాలు, నివారణ చిట్కాలు మరియు అంతర్దృష్టులు."
    keywords={['కార్డియాక్ ఆరోగ్య బ్లాగ్', 'గుండె ఆరోగ్య చిట్కాలు', 'గుంటూరు కార్డియాలజిస్ట్ బ్లాగ్']}
    canonicalUrl="https://kamalakarheartcentre.com/te/blog/"
    lang="te"
    alternateLangUrl="https://kamalakarheartcentre.com/blog/"
    schemas={schemas}
    page="home"
  />

  <Header
    client:load
    lang="te"
    content={content.nav}
    appointmentPhone={content.contact.appointmentPhone}
    currentPage="blog"
    currentPath={Astro.url.pathname}
  />

  <main id="main-content" aria-label="బ్లాగ్">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-4">
      <ol class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
        <li>
          <a href="/te/" class="hover:text-primary dark:hover:text-white transition-colors">హోమ్</a>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li class="text-primary dark:text-white font-medium" aria-current="page">బ్లాగ్</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="bg-gradient-to-br from-primary/5 to-transparent dark:from-primary/10 py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white dark:bg-primary/50 text-primary dark:text-white mb-6 border border-gray-100 dark:border-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
          <span class="text-sm font-bold uppercase tracking-wider">డాక్టర్ కమలాకర్ నుండి</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold font-serif text-primary dark:text-white mb-6 leading-tight">
          గుండె ఆరోగ్య బ్లాగ్
        </h1>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-3xl leading-relaxed">
          కార్డియాక్ ఆరోగ్యం, నివారణ వ్యూహాలు మరియు గుండె సంరక్షణలో తాజా పురోగతులపై నిపుణ అంతర్దృష్టులు.
        </p>
      </div>
    </section>

    <!-- Blog Posts Grid -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-gray-500 dark:text-gray-400 text-lg">బ్లాగ్ పోస్ట్‌లు త్వరలో వస్తాయి. అప్‌డేట్స్ కోసం వేచి ఉండండి!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {posts.map((post) => (
            <a
              href={`/te/blog/${post.id}/`}
              class="group bg-white dark:bg-gray-800 rounded-2xl overflow-hidden border border-gray-100 dark:border-gray-700 hover:shadow-xl hover:border-primary/20 transition-all duration-300 hover:-translate-y-1"
            >
              <div class="p-8">
                <div class="flex items-center gap-3 mb-4">
                  <time
                    datetime={post.data.date.toISOString()}
                    class="text-xs font-bold text-gray-400 uppercase tracking-wider"
                  >
                    {post.data.date.toLocaleDateString('te-IN', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>

                <h2 class="text-xl font-bold font-serif text-primary dark:text-white mb-3 group-hover:text-accent dark:group-hover:text-accent-light transition-colors leading-tight">
                  {post.data.titleTe || post.data.title}
                </h2>

                <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed mb-6 line-clamp-3">
                  {post.data.summaryTe || post.data.summary}
                </p>

                {(post.data.tagsTe || post.data.tags) && (
                  <div class="flex flex-wrap gap-2 mb-6">
                    {(post.data.tagsTe || post.data.tags)!.slice(0, 3).map((tag) => (
                      <span class="px-2.5 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 text-xs font-medium rounded-full">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}

                <div class="flex items-center justify-between">
                  <span class="text-sm text-gray-500 dark:text-gray-400 font-medium">
                    {post.data.author}
                  </span>
                  <span class="inline-flex items-center gap-1 text-sm font-bold text-primary dark:text-white group-hover:translate-x-1 transition-transform">
                    వ్యాసం చదవండి
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- CTA -->
    <section class="bg-primary dark:bg-primary-light py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold font-serif text-white mb-6">మీ గుండె ఆరోగ్యం గురించి ప్రశ్నలు ఉన్నాయా?</h2>
        <p class="text-white/80 mb-8 max-w-2xl mx-auto">గుంటూరులో కమలాకర్ హార్ట్ సెంటర్‌లో వ్యక్తిగత కార్డియాక్ సంరక్షణ కోసం డాక్టర్ కమలాకర్‌తో సంప్రదింపు బుక్ చేయండి.</p>
        <a
          href={`tel:${content.contact.appointmentPhone}`}
          class="inline-flex items-center gap-3 bg-white text-primary px-8 py-4 rounded-xl font-bold text-lg shadow-lg hover:bg-gray-100 transition-all hover:-translate-y-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          అపాయింట్‌మెంట్ బుక్ చేయండి
        </a>
      </div>
    </section>
  </main>

  <Footer content={content.footer} navContent={content.nav} lang="te" currentPage="blog" />
</BaseLayout>
