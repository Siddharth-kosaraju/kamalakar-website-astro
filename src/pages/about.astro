---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';
import { getSiteContent } from '../utils/content';
import { buildPhysicianSchema, buildWebPageSchema } from '../utils/schemas';

const content = await getSiteContent();

const schemas = [
  buildPhysicianSchema(),
  {
    '@context': 'https://schema.org',
    '@type': 'MedicalWebPage',
    url: 'https://kamalakarheartcentre.com/about/',
    name: 'About Dr Kamalakar Kosaraju | Cardiologist in Guntur',
    description: 'About Dr Kamalakar Kosaraju top cardiologist in Guntur specializing in interventional cardiology heart checkups angioplasty and advanced cardiac care.',
    inLanguage: 'en',
    isPartOf: { '@type': 'WebSite', url: 'https://kamalakarheartcentre.com', name: 'Kamalakar Heart Centre' },
    about: { '@type': 'Physician', '@id': 'https://kamalakarheartcentre.com/#physician' },
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['#about-heading', '#about-bio'],
    },
  },
];
---

<BaseLayout class="min-h-screen bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300">
  <SEO
    slot="head"
    title="About Dr Kamalakar Kosaraju | Cardiologist in Guntur"
    description="Meet Dr Kamalakar Kosaraju — Interventional Cardiologist in Guntur. MD General Medicine, DM Cardiology (Dr. NTR University), Osmania Medical College alumnus, FESC. AP MC #57814."
    keywords={['about dr kamalakar kosaraju', 'cardiologist in guntur', 'heart specialist in guntur', 'interventional cardiologist guntur', 'best cardiologist in guntur', 'heart doctor guntur', 'cardiac specialist guntur', 'angioplasty doctor guntur']}
    canonicalUrl="https://kamalakarheartcentre.com/about/"
    schemas={schemas}
    page="home"
  />

  <Header
    client:load
    content={content.nav}
    appointmentPhone={content.contact.appointmentPhone}
    currentPage="about"
    currentPath={Astro.url.pathname}
  />

  <main id="main-content" aria-label="About Dr. Kamalakar">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-1">
      <ol class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
        <li>
          <a href="/" class="hover:text-primary dark:hover:text-white transition-colors">Home</a>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li class="text-primary dark:text-white font-medium" aria-current="page">About Doctor</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="bg-gradient-to-br from-primary/5 to-transparent dark:from-primary/10 py-6 md:py-8">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 id="about-heading" class="text-[28px] md:text-5xl font-bold font-serif text-primary dark:text-white mb-6 leading-tight">
          About Dr Kamalakar Kosaraju – Cardiologist
        </h1>
        <p class="text-base md:text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed font-medium">
          Experienced interventional cardiologist in Guntur providing advanced cardiac diagnosis and treatment at Kamalakar Heart Centre.
        </p>
      </div>
    </section>

    <!-- Doctor Profile — Photo + Bio intro -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-16">
      <div id="about-bio" class="lg:grid lg:grid-cols-5 lg:gap-12 lg:items-start">
        <!-- Image -->
        <div class="lg:col-span-2 mb-6 lg:mb-0">
          <div class="relative border-4 border-primary/10 dark:border-gray-700 rounded-3xl overflow-hidden shadow-xl">
            <picture>
              <source srcset="/media/dr-kamalakar.webp" type="image/webp" />
              <img
                src="/media/dr-kamalakar.jpg"
                width="600"
                height="800"
                loading="eager"
                decoding="async"
                alt="Dr. Kamalakar Kosaraju - Best Cardiologist in Guntur | Interventional Cardiologist at Kamalakar Heart Centre"
                class="w-full h-auto object-cover aspect-[3/4]"
              />
            </picture>
          </div>
        </div>

        <!-- Bio intro -->
        <div class="lg:col-span-3 space-y-3 md:space-y-5 text-gray-700 dark:text-gray-300 leading-relaxed">
          <p class="text-base md:text-lg">Dr. Kamalakar Kosaraju is a highly experienced <strong>cardiologist in Guntur, Andhra Pradesh</strong> specializing in interventional cardiology and advanced cardiac treatment. With more than a decade of clinical experience, he has helped thousands of patients manage heart disease and improve long-term cardiovascular health.</p>
          <p class="text-base md:text-lg">Known for his accurate diagnosis and patient-focused care, Dr. Kamalakar treats a wide range of heart conditions including coronary artery disease, chest pain, hypertension, heart failure, and other cardiovascular disorders.</p>
          <p class="text-base md:text-lg">Patients visit from across Guntur and nearby regions seeking consultation for heart checkups, cardiac evaluation, and advanced heart treatment.</p>
        </div>
      </div>
    </section>

    <!-- Credentials — full-width highlight strip -->
    <section class="bg-neutral-50 dark:bg-gray-800/50 border-y border-gray-200 dark:border-gray-700">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-10">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="p-5 rounded-xl bg-white dark:bg-gray-800 border border-blue-200 dark:border-blue-800/50 shadow-sm">
            <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-1">Education</p>
            <p class="font-bold text-gray-900 dark:text-white">M.D. General Medicine</p>
            <p class="text-xs text-amber-600 font-bold mt-0.5">Gold Medalist</p>
          </div>
          <div class="p-5 rounded-xl bg-white dark:bg-gray-800 border border-blue-200 dark:border-blue-800/50 shadow-sm">
            <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-1">Specialization</p>
            <p class="font-bold text-gray-900 dark:text-white">D.M. Cardiology</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Osmania Medical College</p>
          </div>
          <div class="p-5 rounded-xl bg-white dark:bg-gray-800 border border-red-200 dark:border-red-800/50 shadow-sm">
            <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-1">Fellowship</p>
            <p class="font-bold text-gray-900 dark:text-white">FESC</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">European Society of Cardiology</p>
          </div>
          <div class="p-5 rounded-xl bg-white dark:bg-gray-800 border border-amber-200 dark:border-amber-800/50 shadow-sm">
            <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wide mb-1">Experience</p>
            <p class="font-bold text-gray-900 dark:text-white">{content.about.experienceBadge}</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">5,000+ Cardiac Procedures</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Education & Training — full-width two-column section -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-16">
      <div class="lg:grid lg:grid-cols-5 lg:gap-12 lg:items-start">
        <div class="lg:col-span-2 mb-4 lg:mb-0">
          <h2 class="text-2xl md:text-4xl font-bold font-serif text-primary dark:text-white leading-tight">Experienced Heart Specialist in Guntur</h2>
        </div>
        <div class="lg:col-span-3 space-y-5 text-gray-700 dark:text-gray-300 leading-relaxed">
          <p class="text-base md:text-lg">Dr. Kamalakar completed his <strong>M.D. in General Medicine as a Gold Medalist</strong> and later pursued <strong>D.M. in Cardiology from Osmania Medical College</strong>, one of the leading medical institutions in India.</p>
          <p class="text-base md:text-lg">His medical training and clinical expertise allow him to provide comprehensive cardiac care including preventive cardiac care, diagnosis, and interventional procedures.</p>
          <p class="text-base md:text-lg">He also holds <strong>FESC Fellowship from the European Society of Cardiology</strong>, reflecting his commitment to international cardiology standards and evidence-based treatment.</p>
        </div>
      </div>
    </section>

    <!-- Areas of Expertise — full-width grid -->
    <section class="bg-neutral-50 dark:bg-gray-800/50 border-y border-gray-200 dark:border-gray-700 py-8 md:py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-bold font-serif text-primary dark:text-white mb-5 md:mb-8 text-center">Areas of Expertise</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="flex items-center gap-3 bg-white dark:bg-gray-800 p-4 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-accent flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Interventional Cardiology</span>
          </div>
          <div class="flex items-center gap-3 bg-white dark:bg-gray-800 p-4 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-accent flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Angioplasty & Stenting</span>
          </div>
          <div class="flex items-center gap-3 bg-white dark:bg-gray-800 p-4 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-accent flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Angiogram (Coronary)</span>
          </div>
          <div class="flex items-center gap-3 bg-white dark:bg-gray-800 p-4 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-accent flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Pacemaker Implantation</span>
          </div>
          <div class="flex items-center gap-3 bg-white dark:bg-gray-800 p-4 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-accent flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Heart Failure Management</span>
          </div>
          <div class="flex items-center gap-3 bg-white dark:bg-gray-800 p-4 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-accent flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-200">ECG & 2D Echocardiography</span>
          </div>
          <div class="flex items-center gap-3 bg-white dark:bg-gray-800 p-4 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-accent flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Hypertension Management</span>
          </div>
          <div class="flex items-center gap-3 bg-white dark:bg-gray-800 p-4 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-accent flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-200">Emergency Cardiac Care</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-primary dark:bg-primary-light py-6 md:py-10">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold font-serif text-white mb-6">Book a Consultation with Dr. Kamalakar</h2>
        <a
          href={`tel:${content.contact.appointmentPhone}`}
          class="inline-flex items-center gap-3 bg-white text-primary px-6 py-3 md:px-8 md:py-4 rounded-xl font-bold text-base md:text-lg shadow-lg hover:bg-gray-100 transition-all hover:-translate-y-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call {content.contact.appointmentPhone}
        </a>
      </div>
    </section>
  </main>

  <Footer content={content.footer} navContent={content.nav} currentPage="about" />
</BaseLayout>
