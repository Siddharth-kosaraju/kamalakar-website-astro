---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';
import { getSiteContent } from '../utils/content';
import { buildPhysicianSchema, buildWebPageSchema } from '../utils/schemas';

const content = await getSiteContent('en');

const schemas = [
  buildPhysicianSchema(),
  {
    '@context': 'https://schema.org',
    '@type': 'MedicalWebPage',
    url: 'https://kamalakarheartcentre.com/about/',
    name: 'About Dr. Kamalakar Kosaraju - Best Cardiologist in Guntur',
    description: 'Dr. Kamalakar Kosaraju is a Gold Medalist Interventional Cardiologist in Guntur with 10+ years experience and 5,000+ cardiac procedures. FESC certified.',
    inLanguage: 'en',
    isPartOf: { '@type': 'WebSite', url: 'https://kamalakarheartcentre.com', name: 'Kamalakar Heart Centre' },
    about: { '@type': 'Physician', '@id': 'https://kamalakarheartcentre.com/#physician' },
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['#about-heading', '#about-bio'],
    },
  },
];
---

<BaseLayout lang="en" class="min-h-screen bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300">
  <SEO
    slot="head"
    title="About Dr. Kamalakar Kosaraju | Best Cardiologist in Guntur"
    description="Dr. Kamalakar Kosaraju is a Gold Medalist Interventional Cardiologist in Guntur with 10+ years experience, 5,000+ cardiac procedures, and FESC certification from the European Society of Cardiology."
    keywords={['Dr. Kamalakar Kosaraju', 'cardiologist Guntur', 'interventional cardiologist Guntur', 'FESC certified cardiologist', 'gold medalist cardiologist Guntur']}
    canonicalUrl="https://kamalakarheartcentre.com/about/"
    lang="en"
    alternateLangUrl="https://kamalakarheartcentre.com/te/about/"
    schemas={schemas}
    page="home"
  />

  <Header
    client:load
    lang="en"
    content={content.nav}
    appointmentPhone={content.contact.appointmentPhone}
    currentPage="about"
    currentPath={Astro.url.pathname}
  />

  <main id="main-content" aria-label="About Dr. Kamalakar">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-4">
      <ol class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
        <li>
          <a href="/" class="hover:text-primary dark:hover:text-white transition-colors">Home</a>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li class="text-primary dark:text-white font-medium" aria-current="page">About Doctor</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="bg-gradient-to-br from-primary/5 to-transparent dark:from-primary/10 py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 id="about-heading" class="text-4xl md:text-5xl font-bold font-serif text-primary dark:text-white mb-6 leading-tight">
          About Dr. Kamalakar Kosaraju
        </h1>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-3xl leading-relaxed">
          Gold Medalist Interventional Cardiologist with over a decade of experience in treating complex cardiac conditions at Life Hospital, Guntur.
        </p>
      </div>
    </section>

    <!-- Doctor Profile -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="lg:grid lg:grid-cols-5 lg:gap-12 lg:items-start">
        <!-- Image -->
        <div class="lg:col-span-2 mb-10 lg:mb-0">
          <div class="relative border-4 border-primary/10 dark:border-gray-700 rounded-3xl overflow-hidden shadow-xl">
            <picture>
              <source srcset="/media/dr-kamalakar.webp" type="image/webp" />
              <img
                src="/media/dr-kamalakar.jpg"
                width="600"
                height="800"
                loading="eager"
                decoding="async"
                alt="Dr. Kamalakar Kosaraju - Best Cardiologist in Guntur | Interventional Cardiologist at Kamalakar Heart Centre"
                class="w-full h-auto object-cover aspect-[3/4]"
              />
            </picture>
          </div>
        </div>

        <!-- Bio -->
        <div id="about-bio" class="lg:col-span-3 space-y-6">
          <div class="space-y-5 text-gray-700 dark:text-gray-300 leading-relaxed">
            <p class="text-base md:text-lg">{content.about.p1}</p>
            <p class="text-base md:text-lg">{content.about.p2}</p>
          </div>

          <!-- Credentials -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-6">
            <div class="p-5 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800/50">
              <p class="text-sm font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Education</p>
              <p class="font-bold text-gray-900 dark:text-white">M.D. General Medicine</p>
              <p class="text-xs text-amber-600 font-bold">Gold Medalist</p>
            </div>
            <div class="p-5 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800/50">
              <p class="text-sm font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Specialization</p>
              <p class="font-bold text-gray-900 dark:text-white">D.M. Cardiology</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">Osmania Medical College</p>
            </div>
            <div class="p-5 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800/50">
              <p class="text-sm font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Fellowship</p>
              <p class="font-bold text-gray-900 dark:text-white">FESC</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">European Society of Cardiology</p>
            </div>
            <div class="p-5 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800/50">
              <p class="text-sm font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Experience</p>
              <p class="font-bold text-gray-900 dark:text-white">{content.about.experienceBadge}</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">5,000+ Cardiac Procedures</p>
            </div>
          </div>

          <!-- Expertise -->
          <div class="pt-6">
            <h2 class="text-2xl font-bold font-serif text-primary dark:text-white mb-4">Areas of Expertise</h2>
            <ul class="grid grid-cols-2 gap-2 text-gray-700 dark:text-gray-300">
              <li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>Interventional Cardiology</li>
              <li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>Angioplasty & Stenting</li>
              <li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>Angiogram (Coronary)</li>
              <li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>Pacemaker Implantation</li>
              <li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>Heart Failure Management</li>
              <li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>ECG & 2D Echocardiography</li>
              <li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>Hypertension Management</li>
              <li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>Emergency Cardiac Care</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-primary dark:bg-primary-light py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold font-serif text-white mb-6">Book a Consultation with Dr. Kamalakar</h2>
        <a
          href={`tel:${content.contact.appointmentPhone}`}
          class="inline-flex items-center gap-3 bg-white text-primary px-8 py-4 rounded-xl font-bold text-lg shadow-lg hover:bg-gray-100 transition-all hover:-translate-y-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call {content.contact.appointmentPhone}
        </a>
      </div>
    </section>
  </main>

  <Footer content={content.footer} navContent={content.nav} lang="en" currentPage="about" />
</BaseLayout>
