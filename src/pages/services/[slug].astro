---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer.astro';
import ServiceFAQ from '../../components/ServiceFAQ';
import { getSiteContent, getServicePage, SERVICE_SLUGS } from '../../utils/content';
import { buildServicePageSchema } from '../../utils/schemas';

export async function getStaticPaths() {
  return SERVICE_SLUGS.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const content = await getSiteContent('en');
const service = await getServicePage(slug!, 'en');

if (!service) {
  return Astro.redirect('/404');
}

const schemas = buildServicePageSchema({
  title: service.title,
  metaDescription: service.metaDescription,
  steps: service.steps,
  faq: service.faq,
  slug: service.slug,
});
---

<BaseLayout class="min-h-screen bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300">
  <SEO
    slot="head"
    title={service.metaTitle}
    description={service.metaDescription}
    keywords={service.keywords || []}
    canonicalUrl={`https://kamalakarheartcentre.com/services/${slug}/`}
    alternateLangUrl={`https://kamalakarheartcentre.com/te/services/${slug}/`}
    schemas={schemas}
    page="service"
  />

  <Header
    client:load
    content={content.nav}
    appointmentPhone={content.contact.appointmentPhone}
    currentPage="services"
    currentPath={Astro.url.pathname}
  />

  <main id="main-content" aria-label="Main content">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-1">
      <ol class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
        <li>
          <a href="/" class="hover:text-primary dark:hover:text-white transition-colors">Home</a>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li>
          <a href="/#services" class="hover:text-primary dark:hover:text-white transition-colors">Services</a>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li class="text-primary dark:text-white font-medium truncate" aria-current="page">
          {service.title}
        </li>
      </ol>
    </nav>

    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-primary/5 to-transparent dark:from-primary/10 py-6 md:py-8">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-[28px] md:text-5xl font-bold font-serif text-primary dark:text-white mb-3 md:mb-6 leading-tight">
          {service.heroHeading}
        </h1>
        <p class="text-base md:text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed font-medium">
          {service.heroSubheading}
        </p>
      </div>
    </section>

    <!-- Service Images -->
    {service.images && service.images.length > 0 && (
      <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2 md:pt-8 md:pb-4">
        <div class="grid gap-6 max-w-3xl mx-auto">
          {service.images.map((image) => (
            <figure class="bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-sm border border-gray-100 dark:border-gray-700">
              <div class="aspect-[16/10] overflow-hidden">
                <img
                  src={image.src}
                  alt={image.alt}
                  width="800"
                  height="500"
                  loading="eager"
                  class="w-full h-full object-cover"
                />
              </div>
              <figcaption class="px-4 py-3 text-center text-sm font-medium text-gray-600 dark:text-gray-400">
                {image.caption}
              </figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}

    <!-- Content -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-8 md:pt-8 md:pb-12">
      {service.sections ? (
        <div class="space-y-8 md:space-y-12">
          {service.sections.map((section) => (
            <div class="space-y-4">
              {section.heading && (
                <h2 class="text-2xl md:text-4xl font-bold font-serif text-primary dark:text-white">
                  {section.heading}
                </h2>
              )}
              {section.paragraphs && section.paragraphs.map((p) => (
                <p class="text-gray-700 dark:text-gray-300 leading-normal md:leading-relaxed text-base md:text-lg">
                  {p}
                </p>
              ))}
              {section.bullets && (
                <ul class="space-y-2 pl-5 list-disc text-gray-700 dark:text-gray-300 text-base md:text-lg leading-normal md:leading-relaxed">
                  {section.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              )}
              {section.closingText && (
                <p class="text-gray-700 dark:text-gray-300 leading-normal md:leading-relaxed text-base md:text-lg">
                  {section.closingText}
                </p>
              )}
            </div>
          ))}
        </div>
      ) : service.content ? (
        <div class="prose prose-lg dark:prose-invert max-w-none space-y-6">
          {service.content.map((paragraph) => (
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed text-base md:text-lg">
              {paragraph}
            </p>
          ))}
        </div>
      ) : null}
    </section>

    <!-- Procedure Steps -->
    {service.steps && service.steps.length > 0 && (
      <section class="bg-neutral-50 dark:bg-gray-800/50 py-6 md:py-10">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-2xl md:text-3xl font-bold font-serif text-primary dark:text-white mb-5 md:mb-8">
            How {service.title} Works
          </h2>
          <div class="grid md:grid-cols-2 gap-4 md:gap-6">
            {service.steps.map((step, idx) => (
              <div class="flex gap-4 bg-white dark:bg-gray-800 p-4 md:p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm">
                  {idx + 1}
                </div>
                <div>
                  <h3 class="font-bold text-primary dark:text-white mb-1">{step.title}</h3>
                  <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                    {step.description}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- FAQ Accordion (React Island) -->
    {service.faq && service.faq.length > 0 && (
      <ServiceFAQ
        client:visible
        items={service.faq}
        heading={`${service.title} – Frequently Asked Questions`}
      />
    )}

    <!-- CTA Section -->
    <section class="bg-primary dark:bg-primary-light py-6 md:py-10">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold font-serif text-white mb-6">
          {service.ctaText}
        </h2>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={`tel:${content.contact.appointmentPhone}`}
            class="inline-flex items-center gap-3 bg-white text-primary px-6 py-3 md:px-8 md:py-4 rounded-xl font-bold text-base md:text-lg shadow-lg hover:bg-gray-100 transition-all hover:-translate-y-1"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {content.contact.appointmentPhone}
          </a>
          <a
            href="/#services"
            class="inline-flex items-center gap-2 text-white/90 hover:text-white font-bold transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            View All Services
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer content={content.footer} navContent={content.nav} currentPage="services" />
</BaseLayout>
