---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEO from '../../../components/SEO.astro';
import Header from '../../../components/Header';
import Footer from '../../../components/Footer.astro';
import ServiceFAQ from '../../../components/ServiceFAQ';
import { getSiteContent, getServicePage, SERVICE_SLUGS } from '../../../utils/content';
import { buildServicePageSchema } from '../../../utils/schemas';

export async function getStaticPaths() {
  return SERVICE_SLUGS.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const content = await getSiteContent('te');
const service = await getServicePage(slug!, 'te');

if (!service) {
  return Astro.redirect('/te/');
}

const schemas = buildServicePageSchema({
  title: service.title,
  metaDescription: service.metaDescription,
  steps: service.steps,
  faq: service.faq,
  slug: service.slug,
});
---

<BaseLayout lang="te" class="min-h-screen bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300">
  <SEO
    slot="head"
    title={service.metaTitle}
    description={service.metaDescription}
    keywords={service.keywords || []}
    canonicalUrl={`https://kamalakarheartcentre.com/te/services/${slug}/`}
    lang="te"
    alternateLangUrl={`https://kamalakarheartcentre.com/services/${slug}/`}
    schemas={schemas}
    page="service"
  />

  <Header
    client:load
    lang="te"
    content={content.nav}
    appointmentPhone={content.contact.appointmentPhone}
    currentPage="services"
    currentPath={Astro.url.pathname}
  />

  <main id="main-content" aria-label="Main content">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-4">
      <ol class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
        <li>
          <a href="/te/" class="hover:text-primary dark:hover:text-white transition-colors">హోమ్</a>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li>
          <a href="/te/#services" class="hover:text-primary dark:hover:text-white transition-colors">సేవలు</a>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li class="text-primary dark:text-white font-medium truncate" aria-current="page">
          {service.title}
        </li>
      </ol>
    </nav>

    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-primary/5 to-transparent dark:from-primary/10 py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl md:text-5xl font-bold font-serif text-primary dark:text-white mb-6 leading-tight">
          {service.heroHeading}
        </h1>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-3xl leading-relaxed">
          {service.heroSubheading}
        </p>
      </div>
    </section>

    <!-- Content Paragraphs -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="prose prose-lg dark:prose-invert max-w-none space-y-6">
        {service.content.map((paragraph) => (
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed text-base md:text-lg">
            {paragraph}
          </p>
        ))}
      </div>
    </section>

    <!-- Procedure Steps -->
    {service.steps && service.steps.length > 0 && (
      <section class="bg-neutral-50 dark:bg-gray-800/50 py-16">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl font-bold font-serif text-primary dark:text-white mb-10">
            {service.title} ప్రక్రియ దశలు
          </h2>
          <div class="grid md:grid-cols-2 gap-6">
            {service.steps.map((step, idx) => (
              <div class="flex gap-4 bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm">
                  {idx + 1}
                </div>
                <div>
                  <h3 class="font-bold text-primary dark:text-white mb-1">{step.title}</h3>
                  <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                    {step.description}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- FAQ Accordion (React Island) -->
    {service.faq && service.faq.length > 0 && (
      <ServiceFAQ
        client:visible
        items={service.faq}
        heading={`${service.title} – తరచుగా అడిగే ప్రశ్నలు`}
      />
    )}

    <!-- CTA Section -->
    <section class="bg-primary dark:bg-primary-light py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold font-serif text-white mb-6">
          {service.ctaText}
        </h2>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={`tel:${content.contact.appointmentPhone}`}
            class="inline-flex items-center gap-3 bg-white text-primary px-8 py-4 rounded-xl font-bold text-lg shadow-lg hover:bg-gray-100 transition-all hover:-translate-y-1"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {content.contact.appointmentPhone}
          </a>
          <a
            href="/te/#services"
            class="inline-flex items-center gap-2 text-white/90 hover:text-white font-bold transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            అన్ని సేవలు చూడండి
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer content={content.footer} navContent={content.nav} lang="te" currentPage="services" />
</BaseLayout>
