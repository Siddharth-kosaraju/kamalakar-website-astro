---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Education from '../components/Education.astro';
import Preventive from '../components/Preventive.astro';
import WhyChoose from '../components/WhyChoose.astro';
import Testimonials from '../components/Testimonials.astro';
import Gallery from '../components/Gallery';
import FAQ from '../components/FAQ';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { getSiteContent } from '../utils/content';
import { buildHomepageSchemaGraph } from '../utils/schemas';
const content = await getSiteContent();

// Single connected JSON-LD graph for the homepage:
//   WebSite → MedicalClinic (#organization, with AggregateRating from testimonials) → Physician (#physician).
// Every other page (about, services, blog) references #organization and #physician
// by @id so Google sees one canonical entity, not parallel copies.
const homepageSchema = buildHomepageSchemaGraph(content.testimonials.items);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Who is Dr. Kamalakar Kosaraju?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Dr. Kamalakar Kosaraju is an Interventional Cardiologist at Kamalakar Heart Centre providing diagnosis and treatment for heart diseases including angioplasty, angiogram, pacemaker implantation, hypertension and heart failure management.',
      },
    },
    {
      '@type': 'Question',
      name: 'Where is Kamalakar Heart Centre located?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Kamalakar Heart Centre is located at Life Hospital, Old Club Road, Kothapet, Guntur, Andhra Pradesh, 522001.',
      },
    },
    {
      '@type': 'Question',
      name: 'What heart treatments are available at Kamalakar Heart Centre?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The centre provides cardiology services including ECG, 2D Echo, angiogram, angioplasty, pacemaker implantation, heart failure treatment, hypertension and cholesterol management.',
      },
    },
    {
      '@type': 'Question',
      name: 'When should I consult a cardiologist?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'You should consult a cardiologist if you experience symptoms like chest pain, shortness of breath, irregular heartbeat, high blood pressure, dizziness, or a family history of heart disease.',
      },
    },
  ],
};

const schemas = [homepageSchema, faqSchema];
---

<BaseLayout class="min-h-screen bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans selection:bg-primary selection:text-white transition-colors duration-300">
  <SEO
    slot="head"
    title={content.seo.homeTitle}
    description={content.seo.homeDescription}
    keywords={content.seo.keywords}
    canonicalUrl="https://kamalakarheartcentre.com/"
    schemas={schemas}
    page="home"
  />

  <Header
    client:load
    content={content.nav}
    appointmentPhone={content.contact.appointmentPhone}
    currentPage="home"
    currentPath={Astro.url.pathname}
  />

  <main id="main-content" aria-label="Main content">
    <Hero content={content.hero} appointmentPhone={content.contact.appointmentPhone} />
    <Stats client:visible content={content.stats} />
    <About content={content.about} />
    <Services content={content.services} />
    <Education content={content.education} />
    {content.preventive && <Preventive content={content.preventive} />}
    {content.whyChoose && <WhyChoose content={content.whyChoose} />}
    <Testimonials content={content.testimonials} />
    <Gallery client:visible content={content.gallery} />
    <FAQ client:visible content={content.faq} />
    <Contact content={content.contact} appointmentContent={content.appointment} />
  </main>

  <Footer content={content.footer} navContent={content.nav} currentPage="home" />
</BaseLayout>
