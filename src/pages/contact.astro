---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';
import { getSiteContent } from '../utils/content';
import { buildBusinessSchema, buildBreadcrumbSchema } from '../utils/schemas';

const content = await getSiteContent('en');

const locationCoords = {
  lat: 16.298329484414772,
  lng: 80.4526551755477,
};
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${locationCoords.lat},${locationCoords.lng}`;

const schemas = [
  buildBusinessSchema(content.testimonials.items),
  buildBreadcrumbSchema([
    { name: 'Home', url: 'https://kamalakarheartcentre.com' },
    { name: 'Contact', url: 'https://kamalakarheartcentre.com/contact/' },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    url: 'https://kamalakarheartcentre.com/contact/',
    name: 'Contact Kamalakar Heart Centre - Book Appointment in Guntur',
    description: 'Contact Kamalakar Heart Centre at Life Hospital, Kothapet, Guntur. Call 99594 23566 to book an appointment with Dr. Kamalakar.',
    inLanguage: 'en',
    isPartOf: { '@type': 'WebSite', url: 'https://kamalakarheartcentre.com', name: 'Kamalakar Heart Centre' },
  },
];
---

<BaseLayout class="min-h-screen bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300">
  <SEO
    slot="head"
    title="Contact Kamalakar Heart Centre | Book Appointment Guntur"
    description="Contact Kamalakar Heart Centre at Life Hospital, Kothapet, Guntur - 522001. Call 99594 23566 to book an appointment with Dr. Kamalakar. OPD: Mon-Sat 10 AM - 6 PM. 24/7 Emergency."
    keywords={['contact cardiologist Guntur', 'book appointment heart specialist Guntur', 'Kamalakar Heart Centre address', 'cardiologist near me Guntur']}
    canonicalUrl="https://kamalakarheartcentre.com/contact/"
    schemas={schemas}
    page="home"
  />

  <Header
    client:load
    content={content.nav}
    appointmentPhone={content.contact.appointmentPhone}
    currentPage="contact"
    currentPath={Astro.url.pathname}
  />

  <main id="main-content" aria-label="Contact Information">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-4">
      <ol class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
        <li>
          <a href="/" class="hover:text-primary dark:hover:text-white transition-colors">Home</a>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </li>
        <li class="text-primary dark:text-white font-medium" aria-current="page">Contact</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="bg-gradient-to-br from-primary/5 to-transparent dark:from-primary/10 py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl md:text-5xl font-bold font-serif text-primary dark:text-white mb-6 leading-tight">
          {content.contact.heading}
        </h1>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-3xl leading-relaxed">
          {content.contact.helpText}
        </p>
      </div>
    </section>

    <!-- Contact Info + Map -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 bg-neutral-50 dark:bg-gray-800 rounded-3xl overflow-hidden shadow-xl border border-gray-100 dark:border-gray-700">
        <!-- Info -->
        <div class="p-8 md:p-12 space-y-10">
          <!-- Address -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-white dark:bg-white/10 rounded-xl flex items-center justify-center text-primary dark:text-accent shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <span class="text-xs font-bold text-primary dark:text-accent-light uppercase tracking-widest mb-1 block">{content.contact.addressLabel}</span>
              {content.contact.address.map((line) => (
                <p class="text-lg font-medium text-primary dark:text-gray-200">{line}</p>
              ))}
              <a
                href={directionsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm font-bold text-primary dark:text-white bg-white dark:bg-white/10 border border-gray-200 dark:border-white/10 px-4 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-white/20 transition-all mt-4"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
                {content.contact.getDirections}
              </a>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-white dark:bg-white/10 rounded-xl flex items-center justify-center text-primary dark:text-accent shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <span class="text-xs font-bold text-primary dark:text-accent-light uppercase tracking-widest mb-1 block">{content.contact.hoursLabel}</span>
              <p class="text-lg font-medium text-primary dark:text-gray-200">{content.contact.hoursText}</p>
              <p class="text-sm text-gray-600 dark:text-gray-400">{content.contact.sundayEmergency}</p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-white dark:bg-white/10 rounded-xl flex items-center justify-center text-primary dark:text-accent shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <span class="text-xs font-bold text-primary dark:text-accent-light uppercase tracking-widest mb-1 block">{content.contact.contactLabel}</span>
              <a href={`tel:${content.contact.appointmentPhone}`} class="block text-xl font-bold text-primary dark:text-white hover:text-accent transition-colors">
                {content.contact.appointmentPhone}
              </a>
              <a href="tel:9959423566" class="block text-lg text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-white transition-colors">99594 23566</a>
            </div>
          </div>

          <!-- CTA -->
          <a
            href={`tel:${content.contact.appointmentPhone}`}
            class="w-full flex items-center justify-center gap-3 bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg shadow-lg hover:bg-primary-light transition-all hover:-translate-y-1"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
            Book Appointment
          </a>
        </div>

        <!-- Map -->
        <div class="relative h-[400px] lg:h-auto overflow-hidden">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3829.4813854104455!2d80.4526551755477!3d16.298329484414772!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3a4a75af425635d7%3A0x5cd530d97e08ed08!2sDr%20Kamalakar%20MD.%20DM.%20Senior%20Interventional%20cardiologist!5e0!3m2!1sen!2sin!4v1768159273997!5m2!1sen!2sin"
            width="100%"
            height="100%"
            style="border: 0"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Kamalakar Heart Centre Location - Life Hospital, Kothapet, Guntur"
            class="grayscale-[0.5] hover:grayscale-0 transition-all duration-700"
          ></iframe>
        </div>
      </div>
    </section>
  </main>

  <Footer content={content.footer} navContent={content.nav} currentPage="contact" />
</BaseLayout>
