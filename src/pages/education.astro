---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';
import VideoGallery from '../components/VideoGallery';
import { getSiteContent } from '../utils/content';
import { buildWebPageSchema, buildVideoListSchema } from '../utils/schemas';

const content = await getSiteContent('en');

const schemas = [
  buildWebPageSchema('education', 'en'),
  buildVideoListSchema(content.education.videos),
];
---

<BaseLayout lang="en" class="min-h-screen bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans transition-colors duration-300">
  <SEO
    slot="head"
    title={content.seo.educationTitle}
    description={content.seo.educationDescription}
    keywords={content.seo.keywords}
    canonicalUrl="https://kamalakarheartcentre.com/education/"
    lang="en"
    alternateLangUrl="https://kamalakarheartcentre.com/te/education/"
    schemas={schemas}
    page="education"
  />

  <Header
    client:load
    lang="en"
    content={content.nav}
    appointmentPhone={content.contact.appointmentPhone}
    currentPage="education"
    currentPath={Astro.url.pathname}
  />

  <div class="min-h-screen pt-28 pb-20 bg-neutral-50 dark:bg-gray-900 transition-colors duration-300">
    <!-- Header -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <h1 id="education-heading" class="text-4xl md:text-5xl font-bold font-serif text-primary dark:text-white mb-4">
        {content.education.heading}
      </h1>
      <p id="education-description" class="text-lg text-secondary dark:text-gray-400 max-w-2xl">
        {content.education.description}
      </p>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20">
      <!-- Video Gallery (React Island) -->
      <VideoGallery
        client:visible
        videos={content.education.videos}
        lang="en"
        labels={{
          featuredVideos: content.education.labels.featuredVideos,
          upNext: content.education.labels.upNext,
          watchNow: content.education.labels.watchNow,
          keywordsLabel: content.education.labels.keywordsLabel,
        }}
      />

      <!-- Articles Section (Static) -->
      <section>
        <div class="flex items-center gap-3 mb-2">
          <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          </div>
          <h2 class="text-2xl font-bold text-primary dark:text-white font-serif">
            {content.education.labels.articles}
          </h2>
        </div>
        {content.education.labels.articlesCuratedBy && (
          <p class="text-sm text-secondary dark:text-gray-400 mb-8 max-w-2xl">
            {content.education.labels.articlesCuratedBy}
          </p>
        )}

        <div class="grid md:grid-cols-2 gap-6">
          {content.education.articles.map((article) => (
            <a
              href={article.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-xl hover:border-primary/20 transition-all duration-300"
            >
              <div class="flex justify-between items-start mb-4">
                <span class="inline-block px-3 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 text-xs font-bold rounded-full">
                  {article.publisher || "Article"}
                </span>
                <span class="text-xs text-gray-400 font-medium">{article.date}</span>
              </div>
              <h3 class="text-xl font-bold text-primary dark:text-white mb-3 group-hover:text-accent dark:group-hover:text-accent-light transition-colors">
                {article.title}
              </h3>
              <p class="text-gray-600 dark:text-gray-300 text-sm line-clamp-2 mb-6">
                {article.summary}
              </p>
              <span class="inline-flex items-center gap-2 text-sm font-bold text-primary dark:text-white group-hover:translate-x-1 transition-transform">
                {content.education.labels.readArticle}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </section>
    </div>
  </div>

  <Footer content={content.footer} navContent={content.nav} lang="en" currentPage="education" />
</BaseLayout>
