---
/**
 * SEO component — renders all meta tags and JSON-LD schemas in <head>.
 * This replaces the runtime DOM manipulation from the old SEO.tsx.
 * Everything is computed at build time.
 */
interface Props {
  title: string;
  description: string;
  keywords?: string[];
  canonicalUrl: string;
  ogImage?: string;
  schemas?: object[];
  page?: 'home' | 'education' | 'service' | 'privacy' | 'terms';
}

const {
  title,
  description,
  keywords = [],
  canonicalUrl,
  ogImage = 'https://kamalakarheartcentre.com/media/dr-kamalakar.jpg',
  schemas = [],
  page = 'home',
} = Astro.props;
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />
{keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

<!-- Canonical -->
<link rel="canonical" href={canonicalUrl} />

<!-- Geo Meta Tags -->
<meta name="geo.region" content="IN-AP" />
<meta name="geo.placename" content="Guntur" />
<meta name="geo.position" content="16.298329;80.452655" />
<meta name="ICBM" content="16.298329, 80.452655" />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Dr. Kamalakar Kosaraju - Kamalakar Heart Centre" />
<meta property="og:locale" content="en_IN" />
<meta property="og:site_name" content="Kamalakar Heart Centre" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@KamalakarHeart" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- JSON-LD Schemas -->
{schemas.map((schema, i) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
