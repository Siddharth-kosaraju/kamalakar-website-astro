---
/**
 * Hero section — static Astro component.
 * Converted from Hero.tsx. No client-side JS needed.
 */
interface Props {
  content: {
    headline: string;
    subHeadline: string;
    bodyText?: string;
    brandLine?: string;
    trustBadge?: string;
    ctaBook: string;
    ctaEmergency: string;
    address: string;
    addressLink: string;
    experience: string;
    experienceLabel: string;
    procedures: string;
    proceduresLabel: string;
    successRate: string;
    successRateLabel: string;
  };
  appointmentPhone: string;
}

const { content, appointmentPhone } = Astro.props;
---

<section id="home" class="relative min-h-screen pt-32 pb-20 overflow-hidden flex items-center bg-neutral-50 dark:bg-primary-dark via-white to-neutral-100">

  {/* Abstract Background Shapes — aria-hidden: purely decorative, no content for assistive tech */}
  <div aria-hidden="true" class="absolute top-0 right-0 w-1/2 h-screen bg-mesh-gradient opacity-60 pointer-events-none"></div>
  <div aria-hidden="true" class="absolute top-20 left-10 w-64 h-64 bg-accent/5 rounded-full filter blur-3xl animate-float pointer-events-none"></div>
  <div aria-hidden="true" class="absolute bottom-10 right-10 w-96 h-96 bg-primary/5 rounded-full filter blur-3xl animate-float pointer-events-none" style="animation-delay: 2s"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="max-w-5xl mx-auto">

      {/* Content Column */}
      <div class="space-y-8 animate-fade-in-up">

        {/* Trust Badge */}
        <div class="text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white dark:bg-primary border border-accent/30 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
            <span class="text-xs font-bold tracking-widest uppercase text-primary dark:text-gray-200" set:html={content.trustBadge || 'Gold Medalist &bull; FESC Certified'}>
            </span>
          </div>
        </div>

        {/* Headline — centered */}
        <h1 id="hero-headline" class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-primary dark:text-white leading-[1.1] text-center">
          {content.headline}
        </h1>

        {/* Body text — left-aligned for readability */}
        <div class="max-w-3xl mx-auto space-y-4">
          <p class="text-base md:text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
            {content.subHeadline}
          </p>
          {content.bodyText && (
            <p class="text-base md:text-lg text-gray-500 dark:text-gray-400 leading-relaxed">
              {content.bodyText}
            </p>
          )}
        </div>

        {/* Address — centered */}
        <div class="text-center">
          <a
            href={content.addressLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-2.5 rounded-2xl bg-white dark:bg-white/5 border border-primary/10 dark:border-white/10 shadow-sm hover:shadow-md hover:border-accent/40 transition-all duration-300 group"
          >
            <div class="p-1.5 rounded-lg bg-accent/10 text-accent group-hover:bg-accent group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <span class="text-sm md:text-base font-medium text-primary dark:text-gray-200">
              {content.address}
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        {/* CTAs */}
        <div class="flex flex-col sm:flex-row items-center gap-4 justify-center pt-2">
          <a
            href={`tel:${appointmentPhone}`}
            class="w-full sm:w-auto px-8 py-4 bg-primary text-white rounded-full font-bold shadow-lg shadow-primary/30 hover:shadow-primary/50 hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>
            <span>{content.ctaBook}</span>
          </a>
          <a
            href={`tel:${appointmentPhone}`}
            class="w-full sm:w-auto px-8 py-4 bg-white dark:bg-transparent border-2 border-primary/10 dark:border-white/20 text-primary dark:text-white rounded-full font-bold hover:bg-neutral-50 dark:hover:bg-white/5 transition-all duration-300 flex items-center justify-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>{content.ctaEmergency}</span>
          </a>
        </div>

        {/* Stats Row */}
        <div class="grid grid-cols-3 gap-6 pt-12 border-t border-gray-200 dark:border-gray-800 mt-8 max-w-2xl mx-auto">
          <div class="text-center space-y-1">
            <p class="text-3xl font-bold font-serif text-primary dark:text-accent-light">{content.experience}</p>
            <p class="text-xs font-bold uppercase tracking-wider text-gray-600 dark:text-gray-400">{content.experienceLabel}</p>
          </div>
          <div class="text-center space-y-1">
            <p class="text-3xl font-bold font-serif text-primary dark:text-white">{content.procedures}</p>
            <p class="text-xs font-bold uppercase tracking-wider text-gray-600 dark:text-gray-400">{content.proceduresLabel}</p>
          </div>
          <div class="text-center space-y-1">
            <p class="text-3xl font-bold font-serif text-primary dark:text-white">{content.successRate}</p>
            <p class="text-xs font-bold uppercase tracking-wider text-gray-600 dark:text-gray-400">{content.successRateLabel}</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
