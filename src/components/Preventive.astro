---
/**
 * Preventive Cardiac Care section — static Astro component.
 * Highlights risk factors and the importance of early cardiac screening.
 */
interface Props {
  content: {
    heading: string;
    description?: string;
    riskFactors: string[];
    closingText?: string;
  };
}

const { content } = Astro.props;

// Shield icon (preventive care)
const shieldIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>`;

// Check icon for risk factor items
const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`;
---

<section id="preventive" class="py-14 md:py-24 bg-white dark:bg-gray-900 border-t border-gray-100 dark:border-gray-800 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">

      {/* Content Side */}
      <div class="mb-8 lg:mb-0">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 dark:bg-primary/20 text-primary dark:text-accent-light rounded-full text-sm font-bold uppercase tracking-wider mb-6 border border-primary/20 dark:border-primary/30">
          <Fragment set:html={shieldIcon} />
          <span>Preventive Cardiac Care</span>
        </div>

        <h2 class="text-3xl md:text-5xl font-bold font-serif text-primary dark:text-white mb-6 leading-tight">
          {content.heading}
        </h2>

        {content.description && (
          <p class="text-base md:text-lg text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
            {content.description}
          </p>
        )}

        <p class="text-base font-semibold text-gray-700 dark:text-gray-300 mb-4">
          Major risk factors for heart disease include:
        </p>

        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 md:gap-3 mb-8">
          {content.riskFactors.map((factor) => (
            <li class="flex items-center gap-3 bg-neutral-50 dark:bg-white/5 px-3 py-2 md:px-4 md:py-3 rounded-xl border border-gray-100 dark:border-white/10">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-primary/10 dark:bg-accent/20 text-primary dark:text-accent flex items-center justify-center">
                <Fragment set:html={checkIcon} />
              </span>
              <span class="text-gray-700 dark:text-gray-200 font-medium">{factor}</span>
            </li>
          ))}
        </ul>

        {content.closingText && (
          <p class="text-base text-gray-600 dark:text-gray-300 leading-relaxed border-l-4 border-accent pl-4 italic">
            {content.closingText}
          </p>
        )}
      </div>

      {/* Visual Side */}
      <div class="relative">
        <div class="absolute -top-8 -right-8 w-40 h-40 bg-primary/5 dark:bg-accent/5 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-8 -left-8 w-32 h-32 bg-accent/5 dark:bg-primary/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative bg-gradient-to-br from-primary to-primary-light rounded-3xl p-5 md:p-8 text-white shadow-2xl overflow-hidden">
          {/* Background pattern */}
          <div class="absolute inset-0 opacity-10" aria-hidden="true">
            <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="preventive-bg-grid" width="32" height="32" patternUnits="userSpaceOnUse">
                  <path d="M 32 0 L 0 0 0 32" fill="none" stroke="white" stroke-width="1"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#preventive-bg-grid)" />
            </svg>
          </div>

          <div class="relative z-10 text-center space-y-4 md:space-y-6">
            {/* Heart icon */}
            <div class="w-20 h-20 mx-auto bg-white/20 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
              </svg>
            </div>

            <div>
              <p class="text-white/80 text-sm font-semibold uppercase tracking-widest mb-2">Preventive Cardiac Care</p>
              <h3 class="text-2xl font-bold font-serif">Early Detection Saves Lives</h3>
            </div>

            <div class="grid grid-cols-3 gap-4 border-t border-white/20 pt-6">
              <div class="text-center">
                <p class="text-3xl font-bold font-serif">80%</p>
                <p class="text-white/70 text-xs mt-1 leading-tight">Heart disease is preventable</p>
              </div>
              <div class="text-center border-x border-white/20">
                <p class="text-3xl font-bold font-serif">6</p>
                <p class="text-white/70 text-xs mt-1 leading-tight">Key risk factors to manage</p>
              </div>
              <div class="text-center">
                <p class="text-3xl font-bold font-serif">1st</p>
                <p class="text-white/70 text-xs mt-1 leading-tight">Step: consult a cardiologist</p>
              </div>
            </div>

            <a
              href="tel:9959423566"
              class="inline-flex items-center gap-2 bg-white text-primary font-bold px-6 py-3 rounded-full shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Book a Preventive Checkup
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
