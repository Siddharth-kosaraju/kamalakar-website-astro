---
/**
 * Why Choose Us section — static Astro component.
 * Highlights key differentiators of Kamalakar Heart Centre.
 */
interface Props {
  content: {
    heading: string;
    subheading?: string;
    points: string[];
    closingText?: string;
  };
}

const { content } = Astro.props;

// Award / star icon for section chip
const awardIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>`;

// Check-circle icon for each point
const checkCircleIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>`;
---

<section id="why-choose" class="py-14 md:py-24 bg-neutral-50 dark:bg-primary-dark border-t border-gray-200 dark:border-gray-800 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {/* Section header */}
    <div class="text-center mb-10 md:mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white dark:bg-white/10 border border-gray-200 dark:border-white/10 text-primary dark:text-white mb-6 font-semibold">
        <Fragment set:html={awardIcon} />
        <span class="text-sm font-bold uppercase tracking-wider">Why Choose Us</span>
      </div>
      <h2 class="text-3xl md:text-5xl font-bold font-serif text-primary dark:text-white mb-6">
        {content.heading}
      </h2>
      {content.subheading && (
        <p class="text-base md:text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto leading-relaxed">
          {content.subheading}
        </p>
      )}
    </div>

    {/* Points grid */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 mb-8 md:mb-12">
      {content.points.map((point, index) => (
        <div class="group flex items-start gap-4 bg-white dark:bg-gray-800/50 p-4 md:p-6 rounded-xl border border-gray-100 dark:border-gray-700 hover:border-accent dark:hover:border-accent hover:shadow-lg transition-all duration-300">
          <span class="flex-shrink-0 w-10 h-10 rounded-full bg-primary/10 dark:bg-accent/20 text-primary dark:text-accent flex items-center justify-center group-hover:bg-primary group-hover:text-white dark:group-hover:bg-accent dark:group-hover:text-primary transition-colors duration-300">
            <Fragment set:html={checkCircleIcon} />
          </span>
          <p class="text-gray-700 dark:text-gray-200 font-medium leading-relaxed pt-1.5">{point}</p>
        </div>
      ))}
    </div>

    {/* Closing text + CTA */}
    <div class="text-center">
      {content.closingText && (
        <p class="text-gray-600 dark:text-gray-300 text-lg max-w-2xl mx-auto mb-8 leading-relaxed">
          {content.closingText}
        </p>
      )}
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="tel:9959423566"
          class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 md:px-8 md:py-4 rounded-full font-bold shadow-lg shadow-primary/30 hover:shadow-primary/50 hover:-translate-y-1 transition-all duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Book Consultation
        </a>
        <a
          href="/about/"
          class="inline-flex items-center gap-2 bg-white dark:bg-transparent border-2 border-primary/20 dark:border-white/20 text-primary dark:text-white px-6 py-3 md:px-8 md:py-4 rounded-full font-bold hover:border-primary dark:hover:border-white transition-all duration-300"
        >
          Learn About Dr. Kamalakar
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>

  </div>
</section>
