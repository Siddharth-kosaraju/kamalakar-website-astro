# AWS Deployment Environment Variables
# Copy this file to .env-stage or .env-prod and fill in the values

# Preferred domain for SEO: use non-www (e.g. kamalakarheartcentre.com).
# If you add www as well, deploy the CloudFront Function in cloudfront-functions/
# to 301-redirect www to non-www (see WWW_TO_NON_WWW_FIX.md).
alternateDomainNames="kamalakarheartcentre.com"

# The ID part of the ACM Certificate ARN (must be in us-east-1 for CloudFront)
# Example: if ARN is arn:aws:acm:us-east-1:123456789:certificate/abcd-1234-efgh
# Then use: abcd-1234-efgh
acmCertificateIdentifier="your-certificate-id"

# Google tags (injected into index.html at build time). Use .env.production or .env-prod for prod build.
# VITE_GA_ADS_ID=AW-xxxxxxxxxx        # Google Ads conversion tag
# VITE_GA_TAG_ID=GT-xxxxxxxx         # Google Tag ID (optional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX # GA4 Measurement ID (optional); enables gtag('config','G-...')
